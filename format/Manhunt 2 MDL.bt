LittleEndian();
typedef struct
{
    int     NextEntryIndexOffset;//if == 0x20, is last entry or just have 1 entry
    int     PrevEntryIndexOffset;//if == 0x20,just have 1 entry
    int     EntryOffset;
    int     zero;
}EntryIndex;//项目索引

typedef struct
{
    int     RootBoneOffset;
    int     zero[3];
    int     unknown;//rootbone flag;
    local int objectInfoIndexOffset = FTell();
    struct  {
        int     FirstObjectInfoOffset;//this position is this objectInfoIndexOffset, if FirstObjectInfoOffset == objectInfoIndexOffset , is not have object
        int     LastObjectInfoOffset;//if firstoffset = lastoffset,just have 1 objectinfo
        int     zero2;
    }objectInfoIndex;
}Entry;//项目

typedef struct
{
    int     NextObjectInfoOffset;//if == objectInfoIndexOffset,is last objectInfo,or just have 1 objectinfo.
    int     PrevObjectInfoOffset;//如果是第一个索引则为objectInfoIndexOffset，第二个就是正常的上个数据了
    int     ObjectParentBoneOffset;//object.transform need *= object.parent.transform
    int     ObjectOffset;
    int     RootEntryOffset;//所属项目的偏移地址
    int     zero;
    int     unknown;//always is 0x3
}ObjectInfo;


/*
typedef struct
{
