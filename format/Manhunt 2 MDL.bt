int     NextBrotherBoneOffset;//if==0,is not have
int     ParentBoneOffset;//if==0,is not have
int     RootBoneOffset;
int     SubBoneOffset;//if==0,is not have
int     BoneHierarchyLevelDataIndexOffset;//通常在第二个骨骼，但是也有个例！！！
